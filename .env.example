# .env.example

# Used for one-time webhook verification (GET)
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# Used for every message signature verification (POST)
WHATSAPP_APP_SECRET=your_app_secret_here

# Used to send messages outbound
WHATSAPP_TOKEN=your_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Redis
REDIS_URL=redis://localhost:6379

# Database
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/kuditracker

# OpenAI
OPENAI_API_KEY=your_key_here

# AWS
AWS_BUCKET_NAME=your_bucket_here